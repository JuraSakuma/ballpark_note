<div style="background: #00BFFF;" class="py-3 mb-4">
  <div class="container d-flex justify-content-between align-items-center">
    <h1 class="text-white fw-bold m-0">⚾ 観戦記録詳細</h1>
    <%= link_to "一覧に戻る", games_path, class: "btn btn-light fw-bold" %>
  </div>
</div>

<div class="container">
  <div class="card border-0 shadow-lg">

    <div class="card-header text-white text-center py-3 fw-bold fs-5" style="background: #00BFFF;">
      <%= @game.watched_date.strftime("%Y年%m月%d日") %> ｜ <%= @game.stadium %>
    </div>

    <div class="card-body p-4">

      <div class="text-center py-3 mb-4" style="background: #f8f9fa; border-radius: 8px;">
        <p class="fw-bold fs-3 m-0">
          <%= @game.home_team %>
          <span class="mx-3 fw-bold" style="font-size: 2rem;">
          <span style="color: <%= @game.hometeam_score > @game.visitorteam_score ? '#007BFF' : 'black' %>;">
            <%= @game.hometeam_score %>
          </span>
            -
          <span style="color: <%= @game.visitorteam_score > @game.hometeam_score ? '#007BFF' : 'black' %>;">
            <%= @game.visitorteam_score %>
          </span>
          </span>
            <%= @game.visitor_team %>
        </p>
      </div>

      <div class="row g-3">
        <div class="col-md-6">
          <div class="p-3 rounded" style="background: #e8f7ff;">
            <p class="text-muted small mb-1 fw-bold">⚾️ ヒーロー選手</p>
            <p class="fw-bold fs-5 m-0"><%= @game.hero_player.presence || "未記録" %></p>
          </div>
        </div>
        <div class="col-md-6">
          <div class="p-3 rounded" style="background: #fff3e0;">
            <p class="text-muted small mb-1 fw-bold">🍺 飲んだお酒の数</p>
            <p class="fw-bold fs-5 m-0"><%= @game.drink_count.presence || "0" %>杯</p>
          </div>
        </div>
      </div>

      <% if @game.memo.present? %>
        <div class="mt-3 p-3 rounded" style="background: #f8f9fa;">
          <p class="text-muted small mb-1 fw-bold">📝 メモ</p>
          <p class="m-0"><%= @game.memo %></p>
        </div>
      <% end %>

    </div>

    <div class="card-footer bg-white border-0 d-flex justify-content-between py-3">
      <%= link_to "編集する", edit_game_path(@game), class: "btn fw-bold text-white", style: "background: #00BFFF; border: none;" %>
      <%= link_to "削除する", game_path(@game), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "btn btn-danger fw-bold" %>
    </div>

  </div>
</div>