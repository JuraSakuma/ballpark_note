<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">

      <div class="card border-0 shadow-lg">
        <div class="card-header text-white text-center py-3 fw-bold fs-4" style="background: #00BFFF;">
          ⚾ ログイン
        </div>
        <div class="card-body p-4">

          <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

            <div class="mb-3">
              <%= f.label :email, "メールアドレス", class: "form-label fw-bold" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg" %>
            </div>

            <div class="mb-3">
              <%= f.label :password, "パスワード", class: "form-label fw-bold" %>
              <%= f.password_field :password, autocomplete: "current-password", class: "form-control form-control-lg" %>
            </div>

            <% if devise_mapping.rememberable? %>
              <div class="mb-3 form-check">
                <%= f.check_box :remember_me, class: "form-check-input" %>
                <%= f.label :remember_me, "ログイン状態を保持する", class: "form-check-label" %>
              </div>
            <% end %>

            <div class="d-grid mt-4">
              <%= f.submit "ログイン", class: "btn btn-lg fw-bold text-white", style: "background: #FF4500; border: none;" %>
            </div>

          <% end %>

          <hr>
          <div class="text-center">
            <%= render "devise/shared/links" %>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>