<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">

      <div class="card border-0 shadow-lg">
        <div class="card-header text-white text-center py-3 fw-bold fs-4" style="background: #00BFFF;">
          ⚾ 新規登録
        </div>
        <div class="card-body p-4">

          <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <div class="mb-3">
              <%= f.label :email, "メールアドレス", class: "form-label fw-bold" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg" %>
            </div>

            <div class="mb-3">
              <%= f.label :password, "パスワード", class: "form-label fw-bold" %>
              <% if @minimum_password_length %>
                <span class="text-muted small">（<%= @minimum_password_length %>文字以上）</span>
              <% end %>
              <%= f.password_field :password, autocomplete: "new-password", class: "form-control form-control-lg" %>
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation, "パスワード確認", class: "form-label fw-bold" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control form-control-lg" %>
            </div>

            <div class="d-grid mt-4">
              <%= f.submit "登録する", class: "btn btn-lg fw-bold text-white", style: "background: #FF4500; border: none;" %>
            </div>

          <% end %>

          <hr>
          <div class="text-center">
            <%= render "devise/shared/links" %>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>